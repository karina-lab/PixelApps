<config>
    <!-- The PSI package can bind to the AI services. -->
    <allow-association target="com.google.android.as" allowed="com.google.android.apps.pixel.psi"  />
    <allow-association target="com.google.android.apps.pixel.psi" allowed="com.google.android.as"  />

    <!-- The PSI package can bind to the open-source PCS component. -->
    <allow-association target="com.google.android.as.oss" allowed="com.google.android.apps.pixel.psi" />
    <allow-association target="com.google.android.apps.pixel.psi" allowed="com.google.android.as.oss" />

    <!-- The Settings intelligence can access psi for Setting search ability. -->
    <allow-association target="com.google.android.apps.pixel.psi" allowed="com.google.android.settings.intelligence" />

    <!-- Allow delegated UI clients to connect to PCS. -->
    <!-- Clients can only interface with the PCC through this open-source PCS component, which will enforce required PCC privacy controls -->
    <allow-association target="com.google.android.as.oss" allowed="com.android.systemui" />
    <allow-association target="com.google.android.as.oss" allowed="com.google.android.apps.pixel.subzero" />
    <allow-association target="com.google.android.as.oss" allowed="com.google.android.apps.messaging" />
    <allow-association target="com.google.android.as.oss" allowed="com.google.android.apps.weather" />
    <allow-association target="com.google.android.as.oss" allowed="com.google.android.dialer" />
    <allow-association target="com.google.android.as.oss" allowed="com.google.android.inputmethod.latin" />

    <!-- The PSI package can bind to the media module. -->
    <allow-association target="com.google.android.apps.pixel.psi" allowed="com.google.android.providers.media.module" />

    <!-- The PSI package can bind to its own service instance across users (e.g., U10 client to U0 service) -->
    <allow-association target="com.google.android.apps.pixel.psi" allowed="com.google.android.apps.pixel.psi" />
</config>
